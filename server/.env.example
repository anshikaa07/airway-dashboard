# ============================================================
# ENVIRONMENT VARIABLES — Airway Traffic Dashboard Server
# Copy this file to .env and fill in your values
# ============================================================

# MongoDB Connection String
# Local:   mongodb://localhost:27017/airway_dashboard
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/airway_dashboard
MONGO_URI=mongodb://localhost:27017/airway_dashboard

# Server Port
PORT=5000

# Node Environment (development | production)
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# How often to simulate new live data (milliseconds)
# 5000 = every 5 seconds
DATA_REFRESH_INTERVAL=5000
